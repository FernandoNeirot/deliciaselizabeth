rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /delicias-productos/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /delicias-productos/{productId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
